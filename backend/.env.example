## API keys
# Required for Gemini chat and embedding.
# Keep real secrets in local .env files only.
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
GEMINI_MODEL=gemini-3-flash-preview
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

## Kakao APIs
# Required for map/place endpoints.
# Either KAKAO_REST_API_KEY or KAKAO_MAP_API_KEY can be used by the map service.
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY_HERE
KAKAO_MAP_API_KEY=
NEXT_PUBLIC_KAKAOMAP_KEY=YOUR_KAKAO_JAVASCRIPT_KEY_HERE
KAKAO_LOCAL_BASE_URL=https://dapi.kakao.com

## Translation API
# Required only if translation endpoints are used.
TRANSLATION_PROVIDER=google
TRANSLATION_API_KEY=
GOOGLE_TRANSLATION_API_URL=https://translation.googleapis.com/language/translate/v2

## Python runtime
PYTHONDONTWRITEBYTECODE=1
PYTHONIOENCODING=utf-8
PYTHONUTF8=1

## PostgreSQL (docker-compose: service `db`)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kgusmart
POSTGRES_HOST=db
POSTGRES_PORT=5432

## SQLAlchemy DB URL
# Use host `db` when running inside Docker Compose.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/kgusmart

# Use host `localhost` when running python scripts/db_setup.py on a local PC.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/kgusmart

## Vector store / Chroma
# Docker Compose uses Chroma server mode.
VECTOR_STORE_MODE=http
VECTOR_STORE_HOST=chroma
VECTOR_STORE_PORT=8000
VECTOR_STORE_COLLECTION_NAME=document_chunks

# Local non-Docker fallback. Use only when running Chroma embedded in-process.
VECTOR_STORE_PATH=.tmp/chroma

## Crawl4AI
# Docker default. For local Windows runs, use a local path such as `.crawl4ai-data`.
CRAWL4_AI_BASE_DIRECTORY=/app/.crawl4ai-data

# Docker image installs Chromium. Local Windows crawl validation may use `chrome`.
CRAWL4AI_BROWSER_CHANNEL=chromium
